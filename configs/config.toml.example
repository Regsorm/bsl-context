# bsl-context-rs — пример конфига.
# Скопировать в configs/config.toml и подправить под свою машину.
# Запуск: bsl-context-rs.exe --config C:\tools\bsl-context-rs\configs\config.toml

# Адрес для bind. Loopback по дефолту — наружу не торчим.
host = "127.0.0.1"

# Порт MCP-сервера. 8007 свободен после декомиссии bsl-platform-context (карточка #252).
port = 8007

# Каталог установки 1С — ОБЯЗАТЕЛЬНО указать явно.
# Внутри должен быть файл shcntx_ru.hbk (синтакс-помощник платформы).
#
# На корпоративных машинах часто стоит несколько версий рядом:
#   C:\Program Files\1cv8\8.3.18.1563\
#   C:\Program Files\1cv8\8.3.21.1624\
#   C:\Program Files\1cv8\8.3.25.1257\
#   C:\Program Files\1cv8\8.3.27.1606\
#   C:\Program Files\1cv8\8.3.27.1786\
# Сервер автоматически НЕ выбирает версию — это ваше осознанное решение,
# потому что в разных версиях платформы могут отличаться сигнатуры методов
# и состав системных перечислений. Укажите ту версию, под которую
# валидируете код. Если оставить поле пустым/закомментировать — сервер
# стартует с /health, но загрузка индекса будет недоступна.
platform_path = 'C:\Program Files\1cv8\8.3.27.1786'

# Каталог логов. run.bat создаёт его до запуска бинарника.
# Туда пишутся: service.YYYY-MM-DD.log (через tracing-appender), stdout.log, stderr.log.
log_dir = 'C:\bsl-context-rs\logs'

# tracing-фильтр. Можно поменять на debug при отладке.
log_level = "info"

# Дефолтный уровень для validate_expression, когда клиент не передал параметр level.
# 1 — статический анализ ссылок с явным именем типа в исходнике (низкий шум, безопасный дефолт).
# 2 — дополнительно локальный type inference в пределах процедуры (Phase 8 MVP):
#     `Х = Новый ТипX`, `Х = ТипY.ЗначениеZ`, `// @type ТипX`. Больше находок, но и больше
#     потенциальных false-positive из-за динамической типизации BSL.
# Значение клампится в [1..=2]. Опечатки в этом поле сервер не валит — просто берёт ближайший
# допустимый уровень.
default_validation_level = 1

# Белый список MCP-инструментов. Без этой секции (или с пустым списком) доступны
# все одиннадцать. Скрытые инструменты не попадают в tools/list и не выполняются при
# прямом вызове; неизвестное имя даёт предупреждение в лог и ни на что не влияет.
#
# [tools]
# enabled = ["validate_module", "get_constructors", "get_enum_values"]

# Внешний источник имён конфигурации: без него validate_module считает опиской
# вызов процедуры, объявленной в другом модуле. Замер на УТ (14905 модулей):
# без источника 1420 находок высокой уверенности, с источником — 44, настоящая одна.
# Без секции валидатор работает как раньше, ничего не зная о конфигурации.
#
# Вариант 1 — собственный индекс: сервер ни от чего не зависит. Базу собирает
# инструмент rebuild_symbol_index (каталог для файла создаётся сам).
#
# [symbol_source]
# kind = "lite"
# root = 'C:\RepoUT'                            # каталог выгрузки конфигурации
# db_path = 'C:\bsl-context-rs\ut_lite.db'      # файл базы
#
# Вариант 2 — прямое чтение базы code-index (только на этой же машине):
#
# [symbol_source]
# kind = "code_index_db"
# db_path = 'C:\RepoUT\.code-index\index.db'
#
# Вариант 3 — через запущенный сервис code-index (машина любая):
#
# [symbol_source]
# kind = "code_index_mcp"
# url = "http://127.0.0.1:8011/mcp"
# repo = "ut"
# timeout_ms = 5000

# Несколько конфигураций сразу. У validate_module и rebuild_symbol_index появляется
# параметр repo = значение поля repo нужной секции. Взаимоисключающе с [symbol_source]
# выше — указаны обе секции сразу, сервер откажется стартовать.
#
# Способ доступа у каждой свой. По скорости: lite и code_index_db читают файл базы
# напрямую — это на порядки быстрее code_index_mcp, где каждое имя уходит отдельным
# запросом по сети к другому процессу.
#
# [[symbol_sources]]
# repo = "ut"
# kind = "lite"
# root = 'C:\RepoUT'
# db_path = 'C:\tools\bsl-context\ut_lite.db'
#
# [[symbol_sources]]
# repo = "bp"
# kind = "code_index_db"
# db_path = 'C:\RepoBP_SS\.code-index\index.db'
#
# [[symbol_sources]]
# repo = "zup"
# kind = "code_index_mcp"
# url = "http://10.0.0.5:8011/mcp"          # code-index на другой машине
# # code_index_repo не задан — в запросах к code-index используется тот же алиас "zup".
# # Нужен, только если в code-index репозиторий зарегистрирован под другим именем:
# # code_index_repo = "zup-prod"
